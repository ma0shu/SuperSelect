<Window x:Class="SuperSelect.App.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        AllowDrop="True"
        Background="{DynamicResource OverlayWindowBackgroundBrush}"
        Width="900"
        SizeToContent="Height"
        MaxHeight="216"
        MinWidth="560"
        MinHeight="48"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        PreviewDragOver="Window_OnPreviewDragOver"
        PreviewDrop="Window_OnPreviewDrop">
    <Window.Resources>
        <SolidColorBrush x:Key="OverlayWindowBackgroundBrush" Color="#F2F2F2" />
        <SolidColorBrush x:Key="OverlayBorderBrush" Color="#E2E8F0" />
        <SolidColorBrush x:Key="OverlayPanelBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="OverlayPrimaryTextBrush" Color="#1E293B" />
        <SolidColorBrush x:Key="OverlaySecondaryTextBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="OverlayMutedTextBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="OverlayFolderIconBrush" Color="#FCD34D" />
        <SolidColorBrush x:Key="OverlayHoverItemBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="OverlaySelectedItemBrush" Color="#EFF6FF" />
        <SolidColorBrush x:Key="OverlayIconButtonBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="OverlayIconButtonHoverBrush" Color="#64748B" />
        <SolidColorBrush x:Key="OverlayIconButtonCheckedBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="OverlayScrollThumbBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="OverlayScrollThumbHoverBrush" Color="#64748B" />
        <SolidColorBrush x:Key="OverlayScrollThumbDraggingBrush" Color="#475569" />

        <Style x:Key="IconToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{DynamicResource OverlayIconButtonBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Host" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource OverlayIconButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource OverlayIconButtonCheckedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="28" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource OverlayIconButtonBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Host" Background="{TemplateBinding Background}" Padding="4,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource OverlayIconButtonHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimScrollThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="{DynamicResource OverlayScrollThumbBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="2" Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource OverlayScrollThumbHoverBrush}" />
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Background" Value="{DynamicResource OverlayScrollThumbDraggingBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SlimScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="{TemplateBinding Width}" Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand"
                                                  Height="0"
                                                  Opacity="0"
                                                  Focusable="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SlimScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand"
                                                  Height="0"
                                                  Opacity="0"
                                                  Focusable="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Margin="0"
            CornerRadius="0"
            BorderThickness="1,0,1,1"
            BorderBrush="{DynamicResource OverlayBorderBrush}"
            Padding="4,4,4,4"
            AllowDrop="True"
            Background="{DynamicResource OverlayWindowBackgroundBrush}"
            PreviewDragOver="Window_OnPreviewDragOver"
            PreviewDrop="Window_OnPreviewDrop">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Height="28"
                        CornerRadius="4"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource OverlayBorderBrush}"
                        Background="{DynamicResource OverlayPanelBackgroundBrush}">
                    <TextBox x:Name="SearchBox"
                             Padding="8,0"
                             FontSize="12"
                             VerticalContentAlignment="Center"
                             BorderThickness="0"
                             Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                             Background="Transparent"
                             TextChanged="SearchBox_OnTextChanged"
                             PreviewKeyDown="SearchBox_OnPreviewKeyDown" />
                </Border>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center">
                    <ToggleButton x:Name="SearchModeButton"
                                  Style="{StaticResource IconToggleButtonStyle}"
                                  ToolTip="搜索模式"
                                  Click="SearchModeButton_OnClick">&#xE721;</ToggleButton>
                    <ToggleButton x:Name="RecentModeButton"
                                  Style="{StaticResource IconToggleButtonStyle}"
                                  ToolTip="最近文件"
                                  Click="RecentModeButton_OnClick">&#xE823;</ToggleButton>
                    <ToggleButton x:Name="TrayModeButton"
                                  Style="{StaticResource IconToggleButtonStyle}"
                                  ToolTip="托盘文件"
                                  Click="TrayModeButton_OnClick">&#xE7BC;</ToggleButton>
                    <ToggleButton x:Name="ExplorerModeButton"
                                  Style="{StaticResource IconToggleButtonStyle}"
                                  ToolTip="资源管理器路径"
                                  Click="ExplorerModeButton_OnClick">&#xE838;</ToggleButton>
                    <ToggleButton x:Name="TypeFilterButton"
                                  Style="{StaticResource IconToggleButtonStyle}"
                                  ToolTip="按文件类型过滤"
                                  Click="TypeFilterButton_OnClick">&#xE71C;</ToggleButton>

                    <Button x:Name="SortButton"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="点击切换搜索排序"
                            Click="SortButton_OnClick">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   Text="&#xE8D1;"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="StatusText"
                       Grid.Row="1"
                       Margin="2,4,2,0"
                       FontSize="11"
                       Foreground="{DynamicResource OverlaySecondaryTextBrush}"
                       Text="输入关键字搜索，或拖文件到此面板加入托盘。"
                       TextTrimming="CharacterEllipsis" />

            <Border x:Name="ResultHost"
                    Grid.Row="2"
                    Margin="0,4,0,0"
                    VerticalAlignment="Top"
                    CornerRadius="4"
                    BorderBrush="{DynamicResource OverlayBorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource OverlayPanelBackgroundBrush}"
                    Visibility="Collapsed">
                <Grid>
                    <ListBox x:Name="ResultList"
                             Margin="0"
                             Padding="0"
                             BorderThickness="0"
                             Background="{DynamicResource OverlayPanelBackgroundBrush}"
                             Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             PreviewMouseWheel="ResultList_OnPreviewMouseWheel"
                             MouseDoubleClick="ResultList_OnMouseDoubleClick"
                             KeyDown="ResultList_OnKeyDown"
                             ContextMenuOpening="ResultList_OnContextMenuOpening">
                        <ListBox.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SlimScrollBarStyle}" />
                            <ContextMenu x:Key="TrayContextMenu" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="置顶" Click="TrayMenuItem_Pin_OnClick" />
                                <MenuItem Header="删除" Click="TrayMenuItem_Delete_OnClick" />
                            </ContextMenu>
                            <ContextMenu x:Key="RecentContextMenu" DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <MenuItem x:Name="RecentBlockFileMenuItem" Header="屏蔽此文件" Click="RecentMenuItem_BlockFile_OnClick" />
                                <MenuItem Header="屏蔽此目录" Click="RecentMenuItem_BlockDirectory_OnClick" />
                            </ContextMenu>
                        </ListBox.Resources>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="6,4"/>
                                <EventSetter Event="PreviewMouseRightButtonDown" Handler="ListBoxItem_PreviewMouseRightButtonDown" />
                                <EventSetter Event="PreviewMouseLeftButtonUp" Handler="ListBoxItem_PreviewMouseLeftButtonUp" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource OverlayHoverItemBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource OverlaySelectedItemBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="4.5*" />
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="Auto" MinWidth="28" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBlock Grid.Column="0"
                                               x:Name="IconText"
                                               FontFamily="Segoe Fluent Icons"
                                               Text="&#xE7C3;"
                                               Foreground="{DynamicResource OverlaySecondaryTextBrush}"
                                               FontSize="14"
                                               VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DisplayName}"
                                               FontSize="12"
                                               Foreground="{DynamicResource OverlayPrimaryTextBrush}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,12,0" />

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SecondaryText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource OverlaySecondaryTextBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,12,0" />

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding SourceLabel}"
                                               FontSize="10"
                                               Foreground="{DynamicResource OverlayMutedTextBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                        <Setter TargetName="IconText" Property="Text" Value="&#xE8D5;" />
                                        <Setter TargetName="IconText" Property="Foreground" Value="{DynamicResource OverlayFolderIconBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <TextBlock x:Name="ResultSummaryText"
                       Grid.Row="3"
                       Margin="2,1,4,0"
                       FontSize="11"
                       Foreground="{DynamicResource OverlaySecondaryTextBrush}"
                       HorizontalAlignment="Right"
                       Visibility="Collapsed" />
        </Grid>
    </Border>
</Window>
